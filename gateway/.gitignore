# Dependencies — never commit node_modules
node_modules/

# Environment variables — NEVER commit .env (contains secrets)
.env
.env.local
.env.production

# Build outputs
dist/
build/

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp

# Test coverage
coverage/

# k6 results (large binary outputs)
k6/results/*.html

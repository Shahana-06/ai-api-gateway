# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# For local dev, use a password. For AWS, switch to IAM token auth (see docs).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_gateway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_POOL_MAX=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=yourpassword   # uncomment for ElastiCache in production

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_real_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── FastAPI AI Service ───────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=10000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
DEFAULT_RATE_LIMIT_RPM=100
